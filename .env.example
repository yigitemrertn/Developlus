# ─────────────────────────────────────────
#  Developlus — Environment Variables
#  Kopyala: cp .env.example .env
# ─────────────────────────────────────────

# Ortam
ENVIRONMENT=development

# PostgreSQL
POSTGRES_DB=developlus
POSTGRES_USER=developlus_user
POSTGRES_PASSWORD=change_me_strong_password_123

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET_KEY=change_me_jwt_secret_key_minimum_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — Alibaba Dashscope (Qwen)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# LiteLLM
LITELLM_MASTER_KEY=sk-developlus-litellm-master-key

# PgAdmin (opsiyonel, sadece --profile tools ile açılır)
PGADMIN_EMAIL=admin@developlus.ai
PGADMIN_PASSWORD=change_me_pgadmin_password

# CORS (frontend URL)
CORS_ORIGINS=http://localhost,http://localhost:3000
